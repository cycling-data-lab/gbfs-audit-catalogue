# Streamlit secrets template — COPY to `.streamlit/secrets.toml` and fill in.
# The real secrets.toml is git-ignored; never commit credentials.
#
# Hosted annotation database (Supabase / PostgreSQL).
# Leave this unset to use the local SQLite file (annotations.db).
#
# Supabase: Project Settings -> Database -> Connection string -> URI,
# and use the "Transaction" pooler (port 6543). Replace [YOUR-PASSWORD].

ANNOTATION_DB_URL = "postgresql://postgres.xxxxxxxx:[YOUR-PASSWORD]@aws-0-eu-west-3.pooler.supabase.com:6543/postgres?sslmode=require"
